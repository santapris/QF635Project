# Binance trading configuration
# Copy this file to .env and fill in your values for local development.

# # Environment selector - tag applied to logs and metrics. Free-form string.
ENVIRONMENT=dev

# Log level — DEBUG, INFO, WARNING, ERROR. Defaults to INFO.
# Set to DEBUG locally for verbose output.
LOG_LEVEL=INFO

# Dashboard WebSocket port. Set to 0 to disable the dashboard server.
DASHBOARD_PORT=8765

# Binance testnet API credentials — used when a venue has credentials_env = "BINANCE_TESTNET".
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Binance live API credentials — used when a venue has credentials_env = "BINANCE_LIVE".
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=
