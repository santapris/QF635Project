# Copy to .env and fill in.

# Tag applied to logs and metrics. Free-form string.
ENVIRONMENT=dev

# Log verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Dashboard WebSocket port. Set to 0 to disable the dashboard server.
DASHBOARD_PORT=8765

# Binance testnet API key — used when a venue has credentials_env = "BINANCE_TESTNET".
BINANCE_TESTNET_API_KEY=

# Binance testnet API secret, paired with BINANCE_TESTNET_API_KEY.
BINANCE_TESTNET_API_SECRET=

# Binance live API key — used when a venue has credentials_env = "BINANCE_LIVE".
BINANCE_LIVE_API_KEY=

# Binance live API secret, paired with BINANCE_LIVE_API_KEY.
BINANCE_LIVE_API_SECRET=
